# Copy to .env for local overrides; DO NOT commit a real .env to git.

# Port the HTTP server listens on (Render injects this automatically in production)
PORT=3000

# Where the SQLite database lives.
# - Local dev: leave unset (defaults to ./pmms.db)
# - Render with persistent disk: /var/data/pmms.db
DB_PATH=

# Password seeded for the 'admin' user on first boot.
# Override this in production!
ADMIN_PASSWORD=admin123

# Session lifetime (hours)
SESSION_TTL_HOURS=8

# Set automatically by Render to "production"
NODE_ENV=development
